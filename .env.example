# NoteKing Pro Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: LLM API Key (MiniMax / OpenAI / DeepSeek / etc.)
NOTEKING_LLM_API_KEY=sk-your-api-key-here

# OPTIONAL: Custom LLM provider
# For MiniMax (recommended, 中国区用户):
# NOTEKING_LLM_BASE_URL=https://api.minimax.chat/v1
# NOTEKING_LLM_MODEL=MiniMax-M2.7
# For MiniMax (international users):
# NOTEKING_LLM_BASE_URL=https://api.minimax.io/v1
# NOTEKING_LLM_MODEL=MiniMax-M2.7

# For DeepSeek:
# NOTEKING_LLM_BASE_URL=https://api.deepseek.com
# NOTEKING_LLM_MODEL=deepseek-chat

# For local Ollama:
# NOTEKING_LLM_BASE_URL=http://localhost:11434/v1
# NOTEKING_LLM_MODEL=qwen2.5

# OPTIONAL: HuggingFace token for pyannote speaker diarization
# Get yours at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxx

# OPTIONAL: Proxy for YouTube access from China
# NOTEKING_PROXY=socks5://127.0.0.1:7890

# OPTIONAL: Bilibili login cookie for HD content
# BILIBILI_SESSDATA=your_sessdata_here
